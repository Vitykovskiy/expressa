{
  "config_version": 1,
  "architecture": {
    "use_fsd": false
  },
  "language": {
    "documentation": "ru",
    "issues": "ru",
    "pull_requests": "ru",
    "comments": "ru",
    "commits": "ru",
    "labels": "en",
    "agent_instructions": "en"
  },
  "workflow": {
    "execution_mode": "autonomous",
    "issue_tracking": "github_issues",
    "project_tracking": "github_project"
  },
  "pull_requests": {
    "enabled": false,
    "creation_mode": "for_significant_tasks",
    "review": {
      "required": false,
      "reviewers": "human"
    },
    "merge": {
      "squash_commits": false,
      "integration_method": "merge",
      "require_green_checks": false,
      "allow_agent_self_merge": false,
      "agent_configure_branch_protection": false
    }
  },
  "project_map": {
    "enabled": true
  }
}
